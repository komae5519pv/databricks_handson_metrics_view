{
  "datasets": [
    {
      "name": "a681c50c",
      "displayName": "drugstore_kpi_metrics",
      "asset_name": "komae_demo_v4.drugstore_kpi.drugstore_kpi_metrics"
    },
    {
      "name": "0639d685",
      "displayName": "drugstore_store_metrics",
      "asset_name": "komae_demo_v4.drugstore_kpi.drugstore_store_metrics"
    },
    {
      "name": "kpi_mom",
      "displayName": "基本KPI月次比較",
      "queryLines": [
        "WITH monthly AS (\n",
        "  SELECT\n",
        "    `売上月`,\n",
        "    MEASURE(`売上合計`) AS `売上合計`,\n",
        "    MEASURE(`客数合計`) AS `客数合計`,\n",
        "    MEASURE(`客単価_客数ベース`) AS `客単価`\n",
        "  FROM\n",
        "    komae_demo_v4.drugstore_kpi.drugstore_kpi_metrics\n",
        "  GROUP BY\n",
        "    `売上月`\n",
        ")\n",
        "SELECT\n",
        "  `売上月`,\n",
        "  `売上合計`,\n",
        "  `客数合計`,\n",
        "  `客単価`,\n",
        "  LAG(`売上合計`) OVER (ORDER BY `売上月`) AS `前月売上`,\n",
        "  LAG(`客数合計`) OVER (ORDER BY `売上月`) AS `前月客数`,\n",
        "  LAG(`客単価`) OVER (ORDER BY `売上月`) AS `前月客単価`\n",
        "FROM\n",
        "  monthly"
      ]
    },
    {
      "name": "food_ratio_mom",
      "displayName": "食品構成比月次比較",
      "queryLines": [
        "WITH monthly AS (\n",
        "  SELECT\n",
        "    `売上月`,\n",
        "    MEASURE(`食品構成比`) AS `食品構成比`\n",
        "  FROM\n",
        "    komae_demo_v4.drugstore_kpi.drugstore_store_metrics\n",
        "  GROUP BY\n",
        "    `売上月`\n",
        ")\n",
        "SELECT\n",
        "  `売上月`,\n",
        "  `食品構成比`,\n",
        "  LAG(`食品構成比`) OVER (ORDER BY `売上月`) AS `前月食品構成比`\n",
        "FROM\n",
        "  monthly"
      ]
    },
    {
      "name": "pharmacy_retail_monthly",
      "displayName": "調剤vs物販月次推移",
      "queryLines": [
        "SELECT\n",
        "  `売上月`,\n",
        "  MEASURE(`調剤売上`) AS `調剤売上`,\n",
        "  MEASURE(`物販売上`) AS `物販売上`\n",
        "FROM\n",
        "  komae_demo_v4.drugstore_kpi.drugstore_store_metrics\n",
        "GROUP BY\n",
        "  `売上月`\n",
        "ORDER BY\n",
        "  `売上月`"
      ]
    },
    {
      "name": "6aadbaf8",
      "displayName": "drugstore_kpi_metrics (Forecasted)",
      "queryLines": [
        "WITH original_table AS (\n",
        "  SELECT\n",
        "    DATE_TRUNC(\"MONTH\", `売上月`) AS ts,\n",
        "    MEASURE(`売上合計`) AS val\n",
        "  FROM\n",
        "    komae_demo_v4.drugstore_kpi.drugstore_kpi_metrics\n",
        "  GROUP BY\n",
        "    1\n",
        "),\n",
        "dates AS (\n",
        "  SELECT\n",
        "    MAX(ts) AS max_date_column,\n",
        "    MIN(ts) AS min_date_column,\n",
        "    MAX_BY(val, ts) AS val\n",
        "  FROM\n",
        "    original_table\n",
        "),\n",
        "forecast_table AS (\n",
        "  SELECT\n",
        "    ts,\n",
        "    val_forecast,\n",
        "    val_upper,\n",
        "    val_lower,\n",
        "    NULL AS val\n",
        "  FROM\n",
        "    AI_FORECAST(\n",
        "      TABLE(original_table),\n",
        "      horizon =>\n",
        "        (\n",
        "          SELECT\n",
        "            max_date_column\n",
        "              + MAKE_DT_INTERVAL(\n",
        "                CAST(FLOOR(DATEDIFF(max_date_column, min_date_column) * 0.5) AS INT),\n",
        "                0,\n",
        "                0,\n",
        "                0\n",
        "              )\n",
        "          FROM\n",
        "            dates\n",
        "        ),\n",
        "      time_col => 'ts',\n",
        "      value_col => 'val'\n",
        "    )\n",
        ")\n",
        "SELECT\n",
        "  ts AS `売上月`,\n",
        "  val_forecast AS `売上合計_forecast`,\n",
        "  val_upper AS `売上合計_upper`,\n",
        "  val_lower AS `売上合計_lower`,\n",
        "  val AS `売上合計`\n",
        "FROM\n",
        "  forecast_table\n",
        "UNION ALL\n",
        "SELECT\n",
        "  ts AS `売上月`,\n",
        "  NULL AS `売上合計_forecast`,\n",
        "  NULL AS `売上合計_upper`,\n",
        "  NULL AS `売上合計_lower`,\n",
        "  val AS `売上合計`\n",
        "FROM\n",
        "  original_table\n",
        "WHERE\n",
        "  ts\n",
        "    < (\n",
        "      SELECT\n",
        "        max_date_column\n",
        "      FROM\n",
        "        dates\n",
        "    )\n",
        "UNION ALL\n",
        "SELECT\n",
        "  max_date_column AS `売上月`,\n",
        "  val AS `売上合計_forecast`,\n",
        "  val AS `売上合計_upper`,\n",
        "  val AS `売上合計_lower`,\n",
        "  val AS `売上合計`\n",
        "FROM\n",
        "  dates"
      ]
    },
    {
      "name": "89068926",
      "displayName": "drugstore_store_metrics (Forecasted)",
      "queryLines": [
        "WITH original_table AS (\n",
        "    SELECT \n",
        "  `売上月` AS 売上月,\n",
        "  MEASURE(`食品構成比`) AS 食品構成比\n",
        "FROM komae_demo_v4.drugstore_kpi.drugstore_store_metrics GROUP BY 1\n",
        "  ),\n",
        "  dates AS (\n",
        "    SELECT \n",
        "      MAX(売上月) AS max_date_column,\n",
        "      MIN(売上月) AS min_date_column,\n",
        "      MAX_BY(食品構成比, 売上月) AS 食品構成比\n",
        "    FROM original_table\n",
        "  ),\n",
        "  forecast_table AS (\n",
        "    SELECT \n",
        "      売上月,\n",
        "      食品構成比_forecast,\n",
        "      食品構成比_upper,\n",
        "      食品構成比_lower,\n",
        "      NULL AS 食品構成比\n",
        "    FROM AI_FORECAST(\n",
        "      TABLE(original_table),\n",
        "      horizon => (\n",
        "        SELECT\n",
        "          max_date_column + MAKE_DT_INTERVAL(CAST(FLOOR(DATEDIFF(max_date_column, min_date_column) * 0.5) AS INT), 0, 0, 0)\n",
        "        FROM dates\n",
        "      ),\n",
        "      time_col => '売上月',\n",
        "      value_col => '食品構成比'\n",
        "    )\n",
        "  )\n",
        "\n",
        "  SELECT * FROM forecast_table\n",
        "  UNION ALL\n",
        "  SELECT\n",
        "    売上月,\n",
        "    NULL AS 食品構成比_forecast,\n",
        "    NULL AS 食品構成比_upper,\n",
        "    NULL AS 食品構成比_lower,\n",
        "    食品構成比\n",
        "  FROM original_table\n",
        "    WHERE 売上月 < (SELECT max_date_column FROM dates)\n",
        "  UNION ALL\n",
        "  SELECT\n",
        "    max_date_column AS 売上月,\n",
        "    食品構成比 AS 食品構成比_forecast,\n",
        "    食品構成比 AS 食品構成比_upper,\n",
        "    食品構成比 AS 食品構成比_lower,\n",
        "    食品構成比\n",
        "  FROM\n",
        "    dates"
      ]
    }
  ],
