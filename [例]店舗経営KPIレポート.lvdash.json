    },
    {
      "name": "0639d685",
      "displayName": "drugstore_store_metrics",
      "asset_name": "komae_demo_v4.drugstore_kpi.drugstore_store_metrics"
    },
    {
      "name": "kpi_mom",
      "displayName": "基本KPI月次比較",
      "queryLines": [
        "WITH monthly AS (\n",
        "  SELECT\n",
        "    `売上月`,\n",
        "    MEASURE(`売上合計`) AS `売上合計`,\n",
        "    MEASURE(`客数合計`) AS `客数合計`,\n",
        "    MEASURE(`客単価_客数ベース`) AS `客単価`\n",
        "  FROM\n",
        "    komae_demo_v4.drugstore_kpi.drugstore_kpi_metrics\n",
        "  GROUP BY\n",
        "    `売上月`\n",
        ")\n",
        "SELECT\n",
        "  `売上月`,\n",
        "  `売上合計`,\n",
        "  `客数合計`,\n",
        "  `客単価`,\n",
        "  LAG(`売上合計`) OVER (ORDER BY `売上月`) AS `前月売上`,\n",
        "  LAG(`客数合計`) OVER (ORDER BY `売上月`) AS `前月客数`,\n",
        "  LAG(`客単価`) OVER (ORDER BY `売上月`) AS `前月客単価`\n",
        "FROM\n",
        "  monthly"
      ]
    },
    {
      "name": "food_ratio_mom",
      "displayName": "食品構成比月次比較",
      "queryLines": [
        "WITH monthly AS (\n",
        "  SELECT\n",
        "    `売上月`,\n",
        "    MEASURE(`食品構成比`) AS `食品構成比`\n",
        "  FROM\n",
        "    komae_demo_v4.drugstore_kpi.drugstore_store_metrics\n",
        "  GROUP BY\n",
        "    `売上月`\n",
        ")\n",
        "SELECT\n",
        "  `売上月`,\n",
        "  `食品構成比`,\n",
        "  LAG(`食品構成比`) OVER (ORDER BY `売上月`) AS `前月食品構成比`\n",
        "FROM\n",
        "  monthly"
      ]
    },
    {
      "name": "pharmacy_retail_monthly",
      "displayName": "調剤vs物販月次推移",
      "queryLines": [
        "SELECT\n",
        "  `売上月`,\n",
        "  MEASURE(`調剤売上`) AS `調剤売上`,\n",
        "  MEASURE(`物販売上`) AS `物販売上`\n",
        "FROM\n",
        "  komae_demo_v4.drugstore_kpi.drugstore_store_metrics\n",
        "GROUP BY\n",
        "  `売上月`\n",
        "ORDER BY\n",
        "  `売上月`"
      ]
    }
  ],
